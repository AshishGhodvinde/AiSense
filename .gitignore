# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
dist/
.env.local
.env.*.local

# ── Python / Backend ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
backend/.venv/
venv/
env/

# ── Secrets (NEVER commit) ────────────────────────────────────────────────────
.env
# .env.example is safe to commit (contains no real secrets)

# ── Model Weights & Dataset Cache ────────────────────────────────────────────
backend/weights/
*.pth
*.pt
*.bin               # HuggingFace raw weights
*.safetensors       # HuggingFace safetensors weights

# ── HuggingFace model cache (auto-downloaded, large) ─────────────────────────
backend/.cache/
~/.cache/huggingface/

# ── Kaggle dataset downloads ──────────────────────────────────────────────────
~/.cache/kagglehub/
backend/data/

# ── OS Files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs & Temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
